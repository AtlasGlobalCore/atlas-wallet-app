# ============================================================
# ATLAS CORE - Environment Variables
# Copia este ficheiro para .env.local (local) ou configura
# diretamente no Dashboard da Vercel (Settings > Environment Variables)
# ============================================================

# ── ATLAS CORE BANKING API (OBRIGATÓRIO) ──
# URL base da API REST do Atlas Core Banking (tua VPS/Backend).
# Esta URL já inclui o path /api/v1 — as rotas são concatenadas diretamente.
#
# Exemplo: https://api.atlasglobal.digital/api/v1
# NUNCA usar 'localhost' — o frontend faz todas as chamadas por aqui.
NEXT_PUBLIC_API_URL=https://api.atlasglobal.digital/api/v1
