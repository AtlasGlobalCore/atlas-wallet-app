# ============================================================
# ATLAS CORE - Environment Variables para Vercel
# Copia este ficheiro para .env.local (local) ou configura
# diretamente no Dashboard da Vercel (Settings > Environment Variables)
# ============================================================

# ── ATLAS CORE BANKING API ──
# URL base da API REST do Atlas Core Banking (tua VPS/Backend)
# Exemplo: https://api.atlascore.io ou https://backend.nexor.com
NEXT_PUBLIC_ATLAS_API_URL=https://api.atlascore.io

# ── OPICIONAL: Binance Public API ──
# O sistema usa a API pública da Binance por defeito (sem key).
# Se quiseres usar a tua própria chave para rate-limit mais alto:
# BINANCE_API_KEY=your_binance_api_key
# BINANCE_API_SECRET=your_binance_api_secret

# ── OPICIONAL: TradingView ──
# Os widgets do TradingView são públicos e gratuitos. Não precisam de API key.

# ── DATABASE (apenas se usares Prisma localmente para desenvolvimento) ──
# Em produção (Vercel), o frontend NÃO se liga à DB diretamente.
# O backend na VPS gere o Supabase via Prisma.
# DATABASE_URL=file:./db/custom.db

# ── OPICIONAL: NextAuth (se ativares autenticação local) ──
# NEXTAUTH_URL=https://atlascore.io
# NEXTAUTH_SECRET=your_random_secret_string_min_32_chars

# ── NOTA IMPORTANTE ──
# Variáveis com prefixo NEXT_PUBLIC_ são expostas ao cliente (browser).
# As restantes são apenas server-side.
# Para a Vercel, adiciona TODAS as variáveis acima em:
# Vercel Dashboard > Projeto > Settings > Environment Variables
# ──────────────────────────────────────────────────────────
