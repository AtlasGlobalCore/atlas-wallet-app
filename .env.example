# Atlas Core Banking — Environment Variables
# Copy this file to .env and fill in the values

# ── Atlas Core Backend API ──
# Include /api/v1 in the URL (e.g. https://api.atlasglobal.digital/api/v1)
NEXT_PUBLIC_API_URL=

# ── Database (SQLite local) ──
DATABASE_URL=file:./db/custom.db

# ── Next Auth (optional) ──
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
